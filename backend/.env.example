# Backend environment variables
# On Render, set these in the hpe-backend service's Environment tab

CI_ENVIRONMENT=production

# MySQL — Render does not provide MySQL natively.
# Use PlanetScale (https://planetscale.com) or Railway (https://railway.app).
DB_HOSTNAME=your-mysql-host
DB_DATABASE=hpe_asset_intelligence
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_PORT=3306

# JWT signing secret — generate a strong random value
JWT_SECRET=your-strong-random-secret

# Frontend Render URL (used for CORS)
CORS_ORIGIN=https://hpe-frontend.onrender.com
